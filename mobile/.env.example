# Copy to .env and adjust as needed. Both must be EXPO_PUBLIC_* to be visible in the JS bundle.
EXPO_PUBLIC_API_BASE_URL=https://clean-car-app.onrender.com
EXPO_PUBLIC_WEB_BASE_URL=https://clean-car-app.onrender.com

# White-label brand this build targets: "car" (default) or "home".
# Selects app identity (app.config.js), theme (constants/colors.js), feature
# flags (constants/brand.ts) and the ?brand= sent to the API.
EXPO_PUBLIC_BRAND=car
