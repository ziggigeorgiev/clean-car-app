      "en": "./assets/locales/en.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.cargrime.app",
      "buildNumber": "1",
      "config": {
        "googleMapsApiKey": "AIzaSyBg5ZdFkbAp-FXRjh11TZ_oU273xKj7PXs"
      },
      "infoPlist": {
        "CFBundleDisplayName": "CarGrime",
        "NSCameraUsageDescription": "CarGrime never uses the camera.",
        "NSPhotoLibraryUsageDescription": "CarGrime never uses your photo library.",
        "NSLocationWhenInUseUsageDescription": "We use your location to set the cleaning address.",
        "NSCalendarsUsageDescription": "Add booking reminders to your calendar.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
