# Mobile app environment.
#
# Any variable prefixed with EXPO_PUBLIC_ is inlined into the JS bundle by
# Expo at build time and is reachable via process.env.EXPO_PUBLIC_* in code.
# Do NOT put secrets here — anything in the bundle is visible to users.

# Backend base URL (FastAPI service).
# Local dev: http://127.0.0.1:8000
# Production: https://clean-car-app.onrender.com
# EXPO_PUBLIC_API_BASE_URL=https://cargrime.de/
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000


# Public website base URL — used by the in-app links to /terms, /privacy, /cancellation.
# EXPO_PUBLIC_WEB_BASE_URL=https://cargrime.de/
EXPO_PUBLIC_WEB_BASE_URL=http://127.0.0.1:8000
