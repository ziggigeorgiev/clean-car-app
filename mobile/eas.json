{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },

  "build": {
    "car-development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "car-development",
      "env": {
        "EXPO_PUBLIC_BRAND": "car",
        "EXPO_PUBLIC_API_BASE_URL": "https://cargrime.de",
        "EXPO_PUBLIC_WEB_BASE_URL": "https://cargrime.de"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },

    "car-preview": {
      "extends": "car-development",
      "developmentClient": false,
      "distribution": "internal",
      "channel": "car-preview",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      }
    },

    "car-production": {
      "autoIncrement": true,
      "channel": "car-production",
      "env": {
        "EXPO_PUBLIC_BRAND": "car",
        "EXPO_PUBLIC_API_BASE_URL": "https://cargrime.de",
        "EXPO_PUBLIC_WEB_BASE_URL": "https://cargrime.de"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },

    "home-development": {
      "extends": "car-development",
      "channel": "home-development",
      "env": {
        "EXPO_PUBLIC_BRAND": "home"
      }
    },

    "home-preview": {
      "extends": "car-preview",
      "channel": "home-preview",
      "env": {
        "EXPO_PUBLIC_BRAND": "home"
      }
    },

    "home-production": {
      "extends": "car-production",
      "channel": "home-production",
      "env": {
        "EXPO_PUBLIC_BRAND": "home"
      }
    }
  },

  "submit": {
    "car-production": {
      "ios": {
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID_EMAIL",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    },

    "home-production": {
      "ios": {
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID_EMAIL",
        "ascAppId": "REPLACE_WITH_HOME_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    }
  }
}
